<div class="veritas-container py-4 px-4" style="background-color: #020617; min-height: 100vh; color: #f8fafc; font-family: 'Space Grotesk', sans-serif;">
  
  <div class="row mb-5">
    <div class="col-12 col-lg-6">
      <div class="veritas-card glass-panel p-4" style="border: 1px solid rgba(0, 240, 255, 0.15); background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(12px); border-radius: 8px;">
        <h3 class="panel-title mb-4" style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; letter-spacing: 0.2em; color: #00f0ff;">
          <i class="fa fa-paper-plane me-2"></i>SYSTEM_INVITATIONS
        </h3>
        
        <p class="text-muted mb-4" style="font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; line-height: 1.6;">
          Generate high-clearance access signals for new potential intelligence nodes. Sent invitations feature full biometric authorization tracks.
        </p>

        <%= form_with url: invite_admin_users_path, method: :post, class: "d-flex gap-2" do |f| %>
          <div class="flex-grow-1">
            <%= f.email_field :email, placeholder: "NODE_ID@VERITAS.IO", class: "form-control bg-transparent border-secondary text-white shadow-none w-100", 
                style: "font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; border-color: rgba(0, 240, 255, 0.2) !important;", required: true %>
          </div>
          <%= f.submit "SEND_INVITATION", class: "btn btn-outline-info veritas-btn-outline px-4", 
              style: "font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em; border-color: #00f0ff; color: #00f0ff;" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-4 neon-header-container">
    <h1 class="admin-dashboard-title neon-text text-cyber-blue">
      <!-- Icon representation in case Bootstrap Icons isn't loaded -->
      <span class="fs-4 me-2">⛨</span> Command Center: Personnel
    </h1>
  </div>

  <% if notice %>
    <div class="alert alert-success cyber-alert cyber-alert-success"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="alert alert-danger cyber-alert cyber-alert-danger"><%= alert %></div>
  <% end %>

  <div class="cyber-table-wrapper">
    <table class="table cyber-table align-middle">
      <thead>
        <tr>
          <th scope="col" class="column-id">UUID</th>
          <th scope="col">IDENTIFIER</th>
          <th scope="col">CREATED</th>
          <th scope="col">ACCESS LEVEL</th>
          <th scope="col" class="text-end">OPERATIONS</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="cyber-table-row">
            <td class="text-muted small neon-dim">
              <%= content_tag :span, "##{user.id}", class: "text-monospace text-cyber-blue" %>
            </td>
            <td>
              <div class="d-flex align-items-center">
                <div class="avatar-circle me-3 <%= user.admin? ? 'neon-border-red' : 'neon-border-blue' %>">
                  <%= user.email[0].upcase %>
                </div>
                <div>
                  <div class="fw-bold text-light"><%= user.email %></div>
                  <div class="text-secondary small" style="color: #8b949e !important;">Status: Active</div>
                </div>
              </div>
            </td>
            <td class="text-secondary small" style="color: #8b949e !important;">
              <%= user.created_at.strftime("%Y-%m-%d %H:%M:%S") %>
            </td>
            <td>
              <% if user.admin? %>
                <span class="cyber-badge badge-admin">
                  ADMIN
                </span>
              <% else %>
                <span class="cyber-badge badge-user">
                  USER
                </span>
              <% end %>
            </td>
            <td class="text-end">
              <div class="d-flex justify-content-end gap-2 cyber-btn-group" role="group">
                <% if user.admin? %>
                  <%= button_to "REVOKE", 
                                toggle_admin_admin_user_path(user), 
                                method: :patch, 
                                class: "btn cyber-btn btn-outline-warning action-btn",
                                data: { turbo_confirm: "Revoke admin access for #{user.email}?" } %>
                <% else %>
                  <%= button_to "GRANT", 
                                toggle_admin_admin_user_path(user), 
                                method: :patch, 
                                class: "btn cyber-btn btn-outline-success action-btn",
                                data: { turbo_confirm: "Grant admin access to #{user.email}?" } %>
                <% end %>

                <%= button_to "TERMINATE", 
                              admin_user_path(user), 
                              method: :delete, 
                              class: "btn cyber-btn btn-outline-danger action-btn",
                              data: { turbo_confirm: "WARNING: Delete system record #{user.email}? This action is irreversible." } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<style>
/* ------------------------------------------------------------
   2026 Admin Dashboard Cyberpunk / Palantir Gotham Aesthetic
------------------------------------------------------------ */

/* Variables / Neon Tokens */
:root {
  --cyber-bg: #050a14;
  --cyber-panel: rgba(10, 15, 25, 0.85);
  --cyber-border: #1a365d;
  
  --neon-blue: #00e5ff;
  --neon-dim-blue: rgba(0, 229, 255, 0.15);
  
  --neon-red: #ff3366;
  --neon-dim-red: rgba(255, 51, 102, 0.15);
  
  --neon-green: #00ff66;
  --neon-dim-green: rgba(0, 255, 102, 0.15);
  
  --neon-yellow: #ffcc00;
}

body {
  background-color: var(--cyber-bg) !important;
  color: #e2e8f0;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}

.text-cyber-blue {
  color: var(--neon-blue) !important;
  text-shadow: 0 0 15px rgba(0, 229, 255, 0.4);
}

.text-monospace {
  font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
  letter-spacing: 0.5px;
}

/* Header */
.neon-header-container {
  border-bottom: 1px solid var(--cyber-border);
  padding-bottom: 1.5rem;
  margin-bottom: 2.5rem;
  position: relative;
}

.neon-header-container::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 200px;
  height: 2px;
  background: var(--neon-blue);
  box-shadow: 0 0 15px var(--neon-blue);
}

.admin-dashboard-title {
  font-weight: 800;
  font-size: 1.75rem;
  text-transform: uppercase;
  letter-spacing: 3px;
  margin: 0;
}

/* Alerts */
.cyber-alert {
  background: var(--cyber-panel);
  border-radius: 4px;
  border-left: 4px solid transparent;
  backdrop-filter: blur(10px);
  color: #fff;
}
.cyber-alert-success {
  border-left-color: var(--neon-green);
  box-shadow: 0 0 15px var(--neon-dim-green);
}
.cyber-alert-danger {
  border-left-color: var(--neon-red);
  box-shadow: 0 0 15px var(--neon-dim-red);
}

/* Table Wrapper */
.cyber-table-wrapper {
  background: var(--cyber-panel);
  border: 1px solid var(--cyber-border);
  border-radius: 8px;
  padding: 1px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(15px);
  overflow: hidden;
  position: relative;
}

.cyber-table-wrapper::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--neon-blue), transparent);
  opacity: 0.7;
}

/* Base Table */
.cyber-table {
  width: 100%;
  margin-bottom: 0;
  color: #94a3b8;
  background-color: transparent !important;
}

.cyber-table thead th {
  background-color: rgba(5, 10, 20, 0.95);
  color: var(--neon-blue);
  font-weight: 600;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  border-bottom: 1px solid var(--cyber-border) !important;
  border-top: none;
  padding: 1.25rem 1rem;
}

.cyber-table tbody tr {
  border-bottom: 1px solid rgba(26, 54, 93, 0.5) !important;
  transition: all 0.25s ease;
  background-color: transparent;
}

.cyber-table tbody tr:hover {
  background-color: rgba(0, 229, 255, 0.04);
  box-shadow: inset 3px 0 0 var(--neon-blue);
}

.cyber-table td {
  padding: 1.25rem 1rem;
  border: none !important;
  vertical-align: middle;
}

.column-id {
  width: 100px;
}

/* Badges */
.cyber-badge {
  padding: 0.4em 0.85em;
  font-size: 0.7rem;
  font-weight: 700;
  border-radius: 3px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  display: inline-block;
}

.badge-admin {
  background-color: var(--neon-dim-red);
  color: var(--neon-red);
  border: 1px solid rgba(255, 51, 102, 0.5);
  box-shadow: 0 0 10px var(--neon-dim-red);
}

.badge-user {
  background-color: var(--neon-dim-blue);
  color: var(--neon-blue);
  border: 1px solid rgba(0, 229, 255, 0.5);
}

/* User Avatar / Icons */
.avatar-circle {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 1.2rem;
  background-color: #0f172a;
}

.neon-border-blue {
  border: 2px solid var(--neon-blue);
  color: var(--neon-blue);
  box-shadow: 0 0 12px var(--neon-dim-blue);
}

.neon-border-red {
  border: 2px solid var(--neon-red);
  color: var(--neon-red);
  box-shadow: 0 0 12px var(--neon-dim-red);
}

/* Buttons */
.cyber-btn {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  padding: 0.4rem 1rem;
  border-width: 1px;
  border-radius: 3px;
  transition: all 0.2s ease;
  background: transparent;
  cursor: pointer;
}

.btn-outline-warning {
  color: var(--neon-yellow);
  border: 1px solid var(--neon-yellow);
}
.btn-outline-warning:hover {
  background-color: rgba(255, 204, 0, 0.15);
  color: var(--neon-yellow);
  box-shadow: 0 0 12px rgba(255, 204, 0, 0.3);
}

.btn-outline-success {
  color: var(--neon-green);
  border: 1px solid var(--neon-green);
}
.btn-outline-success:hover {
  background-color: var(--neon-dim-green);
  color: var(--neon-green);
  box-shadow: 0 0 12px rgba(0, 255, 102, 0.3);
}

.btn-outline-danger {
  color: var(--neon-red);
  border: 1px solid var(--neon-red);
}
.btn-outline-danger:hover {
  background-color: var(--neon-dim-red);
  color: var(--neon-red);
  box-shadow: 0 0 12px rgba(255, 51, 102, 0.3);
}

/* Reset default button style when inside form/button_to */
.button_to {
  display: inline-block;
  margin: 0;
}
</style>
