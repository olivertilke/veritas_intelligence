<div class="p-4" style="height: calc(100vh - 64px); overflow-y: auto; background: #0a0f1a;">
  <div class="container-fluid px-4 px-md-5">

    <!-- Intelligence Brief Header — Classified Dossier Style -->
    <div class="article-brief-header mb-5 mt-3 position-relative">
      <!-- Top borderline with glow -->
      <div style="height: 1px; background: linear-gradient(90deg, transparent, rgba(56,189,248,0.6), transparent); margin-bottom: 18px;"></div>

      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
          <!-- Classification badge row -->
          <div class="d-flex align-items-center gap-3 mb-2">
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #ef4444; letter-spacing: 3px; border: 1px solid rgba(239,68,68,0.4); padding: 2px 10px; border-radius: 2px;">
              &#9632; CLASSIFIED
            </span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: rgba(56,189,248,0.6); letter-spacing: 2px;">
              VERITAS // INTELLIGENCE BRIEF
            </span>
          </div>

          <!-- Main title -->
          <h1 style="
            font-family: 'Inter', sans-serif;
            font-size: clamp(1.5rem, 4vw, 3rem);
            font-weight: 800;
            color: white;
            letter-spacing: -0.03em;
            line-height: 1.1;
            margin: 0 0 12px 0;
          ">
            <%= @article.headline %>
          </h1>

          <!-- Meta row -->
          <div class="d-flex flex-wrap gap-4 align-items-center" style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #64748b;">
            <span><i class="fa fa-hashtag me-1" style="color: #38BDF8;"></i> RECORD_<%= @article.id %></span>
            <span><i class="fa fa-globe me-1" style="color: #38BDF8;"></i> <%= @article.source_name %></span>
            <span><i class="fa fa-clock me-1" style="color: #38BDF8;"></i> <%= @article.published_at.strftime("%b %d, %Y %H:%M") %> UTC</span>
            <span><i class="fa fa-map-marker-alt me-1" style="color: #38BDF8;"></i> <%= @article.country.name %> / <%= @article.region.name %></span>
          </div>
        </div>

        <!-- Back button — styled as a terminal command -->
        <%= link_to root_path, style: "
          font-family: 'JetBrains Mono', monospace;
          font-size: 0.75rem;
          color: rgba(56,189,248,0.7);
          border: 1px solid rgba(56,189,248,0.2);
          padding: 10px 20px;
          border-radius: 2px;
          text-decoration: none;
          letter-spacing: 2px;
          background: rgba(56,189,248,0.05);
          white-space: nowrap;
          transition: all 0.2s;
          display: inline-block;
        " do %>
          <i class="fa fa-arrow-left me-2"></i>RETURN_TO_WAR_ROOM
        <% end %>
      </div>

      <!-- Bottom borderline -->
      <div style="height: 1px; background: linear-gradient(90deg, rgba(56,189,248,0.3), transparent); margin-top: 20px;"></div>
    </div>

    <!-- Main Content Grid -->
    <div class="row g-4">
      <!-- Left Column: Article Content -->
      <div class="col-md-8">
        <div class="veritas-feed-card h-100" style="background: rgba(13, 17, 23, 0.9); padding: 2rem;">
          <!-- Geolocation compact bar -->
          <div class="d-flex flex-wrap gap-4 mb-4 pb-3" style="border-bottom: 1px solid rgba(56,189,248,0.1);">
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #64748b;">
              <i class="fa fa-map-marker-alt me-1" style="color: #38BDF8;"></i>
              <%= @article.region.name %> / <%= @article.country.name %> [<%= @article.country.iso_code %>]
            </span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #64748b;">
              <i class="fa fa-crosshairs me-1" style="color: #38BDF8;"></i>
              <%= @article.latitude.round(4) %>°, <%= @article.longitude.round(4) %>°
            </span>
          </div>

          
          <div class="veritas-article-content mt-5 mb-4 px-3" style="color: #E2E8F0; font-size: 1.15rem; line-height: 1.8; font-family: 'Merriweather', Georgia, serif; max-height: 65vh; overflow-y: auto; padding-right: 20px;">
            <% if @article.content.present? %>
              <div class="article-body-format">
                <%= raw @article.content %>
              </div>
            <% else %>
              <div class="text-center text-muted p-5">
                <i class="fa fa-robot fa-2x mb-3" style="color: #38BDF8;"></i>
                <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">
                  ESTABLISHING SECURE CONNECTION TO EXTERNAL SERVER...<br>
                  DOWNLOADING RAW DOCUMENT STREAM...
                </p>
              </div>
            <% end %>
          </div>

          <style>
            .article-body-format p {
              margin-bottom: 1.5em;
              color: rgba(255, 255, 255, 0.85);
            }
            .article-body-format p:first-of-type::first-letter {
              font-size: 3.5rem;
              font-weight: bold;
              float: left;
              line-height: 1;
              margin-right: 0.15em;
              color: #38BDF8;
              font-family: 'Inter', sans-serif;
            }
            .article-body-format img, .article-body-format picture, .article-body-format figure {
              max-width: 100%;
              height: auto;
              border-radius: 4px;
              margin: 2rem 0;
              border: 1px solid rgba(56, 189, 248, 0.2);
              box-shadow: 0 4px 20px rgba(0,0,0,0.5);
            }
            .article-body-format figcaption {
              font-family: 'Inter', sans-serif;
              font-size: 0.85rem;
              color: #94A3B8;
              text-align: center;
              margin-top: 0.5rem;
              font-style: italic;
            }
            .article-body-format h2, .article-body-format h3 {
              font-family: 'Inter', sans-serif;
              color: white;
              margin-top: 2.5rem;
              margin-bottom: 1rem;
              font-weight: 600;
              letter-spacing: -0.02em;
            }
            .article-body-format a {
              color: #38BDF8;
              text-decoration: none;
              border-bottom: 1px dotted rgba(56, 189, 248, 0.5);
            }
            .article-body-format a:hover {
              color: white;
              border-bottom-color: white;
            }
          </style>

          <hr class="veritas-divider">
          
          <div class="mt-4 pb-3">
            <a href="<%= @article.source_url %>" target="_blank" class="btn btn-outline-info veritas-btn-outline w-100" style="font-family: 'JetBrains Mono', monospace; letter-spacing: 2px;">
              <i class="fa fa-external-link-alt me-2"></i> ACCESS ORIGINAL SOURCE
            </a>
          </div>
        </div>
      </div>

      <!-- Right Column: VERITAS Triad AI Analysis -->
      <div class="col-md-4">
        <div class="veritas-feed-card h-100" style="background: rgba(13, 17, 23, 0.95); padding: 1.5rem;">
          
          <% analysis = @article.ai_analysis %>
          <% status = analysis&.analysis_status %>

          <!-- Panel Header -->
          <div class="d-flex align-items-center justify-content-between mb-4 pb-3" style="border-bottom: 1px solid rgba(56,189,248,0.15);">
            <div class="d-flex align-items-center gap-2">
              <span style="color: #38BDF8; font-size: 0.8rem;">&#9654;</span>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: white; letter-spacing: 2px;">VERITAS_TRIAD</span>
            </div>
            <% if status == 'complete' %>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #22c55e; border: 1px solid rgba(34,197,94,0.3); padding: 2px 8px; border-radius: 2px;">VERIFIED</span>
            <% elsif status == 'analyzing' %>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #f59e0b; border: 1px solid rgba(245,158,11,0.3); padding: 2px 8px; border-radius: 2px;">ANALYZING</span>
            <% else %>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #64748b; border: 1px solid rgba(100,116,139,0.3); padding: 2px 8px; border-radius: 2px;">QUEUED</span>
            <% end %>
          </div>

          <% if status == 'complete' %>
            <!-- ━━━ TRUST SCORE GAUGE ━━━ -->
            <% trust = analysis.trust_score.to_i %>
            <% trust_color = trust >= 70 ? '#22c55e' : trust >= 40 ? '#f59e0b' : '#ef4444' %>
            <div class="text-center mb-4">
              <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #64748b; letter-spacing: 3px; margin-bottom: 8px;">TRUST SCORE</div>
              <div style="font-family: 'Inter', sans-serif; font-size: 3.5rem; font-weight: 800; color: <%= trust_color %>; line-height: 1;">
                <%= trust %>
              </div>
              <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: #64748b;">/100</div>
              <!-- Trust bar -->
              <div style="width: 100%; height: 4px; background: rgba(255,255,255,0.05); border-radius: 4px; margin-top: 10px; overflow: hidden;">
                <div style="width: <%= trust %>%; height: 100%; background: <%= trust_color %>; border-radius: 4px; transition: width 1s ease;"></div>
              </div>
            </div>

            <!-- ━━━ KEY METRICS ━━━ -->
            <% threat_colors = { 'CRITICAL' => '#ef4444', 'HIGH' => '#f97316', 'MODERATE' => '#f59e0b', 'LOW' => '#22c55e', 'NEGLIGIBLE' => '#64748b' } %>
            <% threat_color = threat_colors[analysis.threat_level] || '#64748b' %>

            <div class="mb-3 py-2" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #64748b;">THREAT LEVEL</span>
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: <%= threat_color %>; font-weight: 700;"><%= analysis.threat_level %></span>
              </div>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #64748b;">SENTIMENT</span>
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: <%= analysis.sentiment_color %>; font-weight: 700;"><%= analysis.sentiment_label %></span>
              </div>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #64748b;">TOPIC</span>
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #38BDF8;"><%= analysis.geopolitical_topic %></span>
              </div>
              <div class="d-flex justify-content-between align-items-center">
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #64748b;">ANOMALIES</span>
                <% if analysis.linguistic_anomaly_flag %>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #ef4444;">&#9888; DETECTED</span>
                <% else %>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #22c55e;">&#10003; CLEAN</span>
                <% end %>
              </div>
            </div>

            <!-- ━━━ AI SUMMARY ━━━ -->
            <div class="mb-3">
              <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #64748b; letter-spacing: 2px; margin-bottom: 6px;">INTELLIGENCE SUMMARY</div>
              <p style="font-family: 'Inter', sans-serif; font-size: 0.85rem; color: rgba(255,255,255,0.8); line-height: 1.6; margin: 0;">
                <%= analysis.summary %>
              </p>
            </div>

            <% if analysis.anomaly_notes.present? && analysis.linguistic_anomaly_flag %>
              <div class="mb-3" style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 4px; padding: 10px;">
                <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: #ef4444; letter-spacing: 2px; margin-bottom: 4px;">&#9888; ANOMALY REPORT</div>
                <p style="font-family: 'Inter', sans-serif; font-size: 0.8rem; color: rgba(239,68,68,0.8); line-height: 1.5; margin: 0;">
                  <%= analysis.anomaly_notes %>
                </p>
              </div>
            <% end %>

            <!-- ━━━ TRIAD AGENT BREAKDOWN ━━━ -->
            <div style="border-top: 1px solid rgba(56,189,248,0.1); padding-top: 12px; margin-top: 8px;">
              <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: #64748b; letter-spacing: 2px; margin-bottom: 10px;">AGENT REPORTS</div>
              
              <% if analysis.arbiter_response.present? %>
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span style="font-size: 0.7rem;">⚖️</span>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: #94a3b8;">
                    CONSENSUS: <span style="color: white;"><%= analysis.arbiter_response['agreement_level'] %></span>
                  </span>
                </div>
              <% end %>

              <div class="d-flex gap-2 mb-2">
                <% analyst_trust = analysis.analyst_response&.dig('trust_score') %>
                <% sentinel_trust = analysis.sentinel_response&.dig('independent_trust_score') %>
                <div style="flex: 1; background: rgba(56,189,248,0.05); border: 1px solid rgba(56,189,248,0.1); border-radius: 4px; padding: 8px; text-align: center;">
                  <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: #64748b;">🔍 ANALYST</div>
                  <div style="font-family: 'Inter', sans-serif; font-size: 1.2rem; font-weight: 700; color: white;"><%= analyst_trust || '--' %></div>
                  <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.5rem; color: #475569;">Gemini</div>
                </div>
                <div style="flex: 1; background: rgba(56,189,248,0.05); border: 1px solid rgba(56,189,248,0.1); border-radius: 4px; padding: 8px; text-align: center;">
                  <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: #64748b;">🛡️ SENTINEL</div>
                  <div style="font-family: 'Inter', sans-serif; font-size: 1.2rem; font-weight: 700; color: white;"><%= sentinel_trust || '--' %></div>
                  <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.5rem; color: #475569;">GPT-4o</div>
                </div>
                <div style="flex: 1; background: rgba(56,189,248,0.05); border: 1px solid rgba(56,189,248,0.1); border-radius: 4px; padding: 8px; text-align: center;">
                  <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: #64748b;">⚖️ ARBITER</div>
                  <div style="font-family: 'Inter', sans-serif; font-size: 1.2rem; font-weight: 700; color: white;"><%= trust %></div>
                  <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.5rem; color: #475569;">Claude</div>
                </div>
              </div>

              <% if analysis.arbiter_response&.dig('arbitration_notes').present? %>
                <div style="margin-top: 8px;">
                  <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: #64748b; letter-spacing: 1px; margin-bottom: 4px;">ARBITER NOTES</div>
                  <p style="font-family: 'Inter', sans-serif; font-size: 0.75rem; color: rgba(255,255,255,0.6); line-height: 1.5; margin: 0;">
                    <%= analysis.arbiter_response['arbitration_notes'] %>
                  </p>
                </div>
              <% end %>
            </div>

          <% elsif status == 'analyzing' %>
            <!-- Analyzing state -->
            <div class="text-center py-5">
              <div style="margin-bottom: 20px;">
                <i class="fa fa-circle-notch fa-spin fa-3x" style="color: #38BDF8;"></i>
              </div>
              <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: white; margin-bottom: 8px;">TRIAD PROCESSING</div>
              <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #64748b; line-height: 1.8;">
                🔍 ANALYST (Gemini Flash)<br>
                🛡️ SENTINEL (GPT-4o-mini)<br>
                ⚖️ ARBITER (Claude Haiku)
              </div>
              <p style="font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #475569; margin-top: 15px;">
                Cross-verifying intelligence...<br>Refresh page in ~15 seconds.
              </p>
            </div>

          <% else %>
            <!-- Queued / Not started state -->
            <div class="text-center py-5">
              <div style="margin-bottom: 20px;">
                <i class="fa fa-satellite-dish fa-2x" style="color: #64748b;"></i>
              </div>
              <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #64748b; line-height: 1.8;">
                ANALYSIS QUEUED<br>
                <span style="font-size: 0.65rem;">3 LLM agents dispatched</span>
              </div>
              <p style="font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #475569; margin-top: 15px;">
                Refresh in ~20 seconds to see results.
              </p>
            </div>
          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>
