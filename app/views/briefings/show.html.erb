<% content_for :title, "Intelligence Briefing — #{@briefing.generated_at&.strftime('%b %d, %Y')}" %>

<div class="container-fluid px-4 py-4" style="font-family: 'JetBrains Mono', monospace; max-width: 1100px;">

  <!-- Header -->
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <div class="d-flex align-items-center gap-3 mb-1">
        <%= link_to briefings_path,
              style: "color: #475569; font-size: 0.65rem; letter-spacing: 2px; text-decoration: none;" do %>
          <i class="fa fa-chevron-left me-1"></i>BRIEFINGS
        <% end %>
        <span style="color: #334155;">·</span>
        <span style="color: #64748b; font-size: 0.65rem; letter-spacing: 1px;">
          DOSSIER-<%= @briefing.id.to_s.rjust(4, '0') %>
        </span>
      </div>
      <h1 style="color: #f8fafc; font-size: 1.3rem; font-weight: 700; letter-spacing: 2px; margin: 0;">
        INTELLIGENCE BRIEFING
        <span style="color: #64748b; font-size: 0.8rem; font-weight: 400; margin-left: 12px;">
          <%= @briefing.generated_at&.strftime("%B %d, %Y — %H:%M UTC") %>
        </span>
      </h1>
    </div>
    <div style="color: #475569; font-size: 0.65rem; letter-spacing: 1px;">
      <i class="fa fa-clock me-1"></i><%= @briefing.age_label %>
    </div>
  </div>

  <!-- Classification banner -->
  <div style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.3);
              border-radius: 4px; padding: 8px 16px; margin-bottom: 28px;
              display: flex; align-items: center; justify-content: center; gap: 16px;">
    <span style="color: #ef4444; font-size: 0.6rem; letter-spacing: 4px;">// VERITAS INTELLIGENCE DOSSIER //</span>
    <span style="width: 30px; height: 1px; background: rgba(239,68,68,0.4); display: inline-block;"></span>
    <span style="color: #ef4444; font-size: 0.6rem; letter-spacing: 3px;">GENERATED BY ARBITER AI</span>
    <span style="width: 30px; height: 1px; background: rgba(239,68,68,0.4); display: inline-block;"></span>
    <span style="color: #ef4444; font-size: 0.6rem; letter-spacing: 4px;">// NOT FOR PUBLIC DISTRIBUTION //</span>
  </div>

  <% sections = @briefing.sections %>

  <% if sections.any? %>
    <!-- Structured sections -->

    <% section_config = {
      "EXECUTIVE SUMMARY"        => { icon: "fa-shield-halved", color: "#ef4444", border: "rgba(239,68,68,0.4)", bg: "rgba(239,68,68,0.04)" },
      "ACTIVE NARRATIVE OPERATIONS" => { icon: "fa-radiation",  color: "#f97316", border: "rgba(249,115,22,0.35)", bg: "rgba(249,115,22,0.04)" },
      "HIGH-PRIORITY SIGNALS"    => { icon: "fa-triangle-exclamation", color: "#eab308", border: "rgba(234,179,8,0.35)", bg: "rgba(234,179,8,0.03)" },
      "UNIQUE INTELLIGENCE"      => { icon: "fa-satellite-dish", color: "#38bdf8", border: "rgba(56,189,248,0.35)", bg: "rgba(56,189,248,0.03)" },
      "ANALYST RECOMMENDATIONS"  => { icon: "fa-list-check",    color: "#22c55e", border: "rgba(34,197,94,0.35)", bg: "rgba(34,197,94,0.04)" }
    } %>

    <div class="d-flex flex-column gap-4">
      <% section_config.each do |title, cfg| %>
        <% content = sections[title] %>
        <% next if content.blank? %>

        <div style="border: 1px solid <%= cfg[:border] %>; border-radius: 6px;
                    padding: 24px; background: <%= cfg[:bg] %>;">
          <div class="d-flex align-items-center gap-3 mb-3">
            <i class="fa <%= cfg[:icon] %>" style="color: <%= cfg[:color] %>; font-size: 0.85rem;"></i>
            <span style="color: <%= cfg[:color] %>; font-size: 0.65rem; letter-spacing: 3px; font-weight: 700;">
              <%= title %>
            </span>
          </div>
          <div style="color: #cbd5e1; font-size: 0.8rem; line-height: 1.8; white-space: pre-wrap;">
            <%= content.gsub(/\[([A-Z]\d+)\]/) { |ref| "<span style='color:#{cfg[:color]};font-weight:700;'>#{ref}</span>" }.html_safe %>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <!-- Raw fallback if sections can't be parsed -->
    <div style="border: 1px solid rgba(71,85,105,0.4); border-radius: 6px; padding: 24px;
                background: rgba(15,23,42,0.5);">
      <div style="color: #cbd5e1; font-size: 0.8rem; line-height: 1.8; white-space: pre-wrap;">
        <%= @briefing.threat_summary %>
      </div>
    </div>
  <% end %>

  <!-- Narrative context footer -->
  <% narratives = @briefing.top_narratives_list %>
  <% if narratives.any? %>
    <div style="margin-top: 32px; border-top: 1px solid rgba(71,85,105,0.3); padding-top: 24px;">
      <div style="color: #475569; font-size: 0.6rem; letter-spacing: 3px; margin-bottom: 14px;">
        CONVERGENCE CONTEXT AT TIME OF BRIEFING
      </div>
      <div class="d-flex flex-wrap gap-3">
        <% narratives.each do |n| %>
          <% threat_color = { 'CRITICAL' => '#ef4444', 'HIGH' => '#f97316', 'MODERATE' => '#eab308' }.fetch(n['threat'], '#475569') %>
          <div style="border: 1px solid rgba(71,85,105,0.4); border-radius: 4px; padding: 10px 14px;
                      background: rgba(15,23,42,0.5); min-width: 200px;">
            <div style="color: <%= threat_color %>; font-size: 0.55rem; letter-spacing: 2px; margin-bottom: 4px;">
              <%= n['threat'] %>
            </div>
            <div style="color: #94a3b8; font-size: 0.7rem; margin-bottom: 4px;"><%= n['label'] %></div>
            <div style="color: #475569; font-size: 0.6rem;"><%= n['article_count'] %> articles</div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Generate new button -->
  <div style="margin-top: 32px; text-align: center;">
    <%= button_to briefings_path,
          method: :post,
          style: "background: transparent; border: 1px solid rgba(71,85,105,0.4); color: #475569;
                  font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 2px;
                  padding: 8px 20px; border-radius: 4px; cursor: pointer;" do %>
      <i class="fa fa-bolt me-2"></i>GENERATE FRESH BRIEFING
    <% end %>
  </div>

</div>
