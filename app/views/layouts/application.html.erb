<!DOCTYPE html>
<html data-bs-theme="dark">
  <head>
    <title>VERITAS // WAR ROOM</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="VERITAS — Real-Time Intelligence Platform for Narrative Warfare">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="veritas-body">
    <!-- Top Navigation Bar -->
    <nav class="navbar veritas-navbar px-3 py-0">
      <a class="navbar-brand veritas-brand" href="<%= root_path %>">
        <span class="brand-pulse"></span>
        <span class="brand-text">VERITAS</span>
        <span class="brand-sub">// WAR ROOM</span>
      </a>

      <div class="navbar-center d-none d-md-flex align-items-center gap-4">
        <div class="veritas-status">
          <span class="status-dot live"></span>
          <span class="status-label">SYSTEM ONLINE</span>
        </div>
      </div>

      <div class="d-flex align-items-center gap-3">
        <% if user_signed_in? %>
          <span class="veritas-meta d-none d-md-inline"><%= current_user.email %></span>
          <%= link_to "SIGN OUT", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-danger btn-sm veritas-btn-outline" %>
        <% else %>
          <%= link_to "SIGN IN", new_user_session_path, class: "btn btn-outline-primary btn-sm veritas-btn-outline" %>
        <% end %>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="veritas-flash veritas-flash-success"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="veritas-flash veritas-flash-danger"><%= alert %></div>
    <% end %>

    <!-- Main Content -->
    <%= yield %>
  </body>
</html>
