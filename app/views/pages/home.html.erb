<!-- VERITAS War Room -->
<div class="veritas-war-room"
     data-controller="narrative-dna tribunal entity-nexus">

<!-- Perspective Lens Compass Bar -->
<div class="veritas-perspective-bar"
     data-controller="perspective">
  <span class="perspective-label">LENS</span>

  <button class="veritas-lens-btn"
          style="--lens-color: #64748b;"
          data-perspective-slug="all"
          data-perspective-target="pill"
          data-action="click->perspective#select">
    <span class="lens-flag">◉</span>
    <span class="lens-label">ALL</span>
  </button>

  <% @perspective_filters.each do |filter| %>
    <button class="veritas-lens-btn"
            style="--lens-color: <%= filter.color %>;"
            data-perspective-slug="<%= filter.slug %>"
            data-perspective-target="pill"
            data-action="click->perspective#select">
      <span class="lens-flag"><%= filter.flag %></span>
      <span class="lens-label"><%= filter.short_label %></span>
    </button>
  <% end %>

  <button class="vt-glass-toggle"
          data-controller="view-mode"
          data-action="click->view-mode#toggle"
          title="Toggle glassmorphism view">
    <span class="vt-glass-toggle-icon">◫</span>
    <span data-view-mode-target="label">SOLID</span>
  </button>
</div>

<!-- Topic Filter Pills Row -->
<div class="veritas-topic-bar"
     data-controller="topic-filter">
  <% %w[NATO BRICS EU UN TRADE_WAR SANCTIONS CYBER CLIMATE NUCLEAR ELECTIONS].each do |topic| %>
    <button class="vt-topic-pill"
            data-topic="<%= topic %>"
            data-topic-filter-target="pill"
            data-action="click->topic-filter#toggle">
      <%= topic.tr('_', ' ') %>
    </button>
  <% end %>
</div>

<!-- VERITAS Main Dashboard -->
<div class="veritas-dashboard" data-controller="journey">

  <!-- LEFT SIDEBAR: Live Intelligence Feed -->
  <aside class="veritas-feed-sidebar mobile-hidden">

    <!-- Search Results Panel: hidden until a search fires veritas:search-results -->
    <div id="intel-search-panel" class="d-none">
      <div class="veritas-panel-header" style="border-color: rgba(0,240,255,0.25);">
        <span class="panel-icon" style="color: #00f0ff;">◉</span>
        <span class="panel-title" id="intel-search-header" style="color: #00f0ff;">SEARCH RESULTS</span>
        <span class="panel-badge" id="intel-search-count" style="background: rgba(0,240,255,0.12); color: #00f0ff;">0</span>
      </div>
      <div id="intel-search-results" class="veritas-feed-list"
           style="border-bottom: 1px solid rgba(0,240,255,0.12); margin-bottom: 6px; padding-bottom: 6px;">
        <%# Populated by search_intelligence_controller.js %>
      </div>
    </div>

    <div class="veritas-panel-header">
      <span class="panel-icon">🔥</span>
      <span class="panel-title">HIGH‑THREAT SIGNALS</span>
      <span class="panel-badge"><%= @hot_articles.count %> HOT</span>
    </div>

    <%= turbo_stream_from "hot_articles" %>
    <div class="veritas-feed-list" id="hot-articles-feed" data-controller="sidebar-limit" data-journey-target="feedList">
      <% @hot_articles.each do |article| %>
        <%= render partial: "articles/sidebar_item", locals: { article: article } %>
      <% end %>
    </div>
  </aside>

  <!-- CENTER: 3D Globe (Globe.gl) -->
  <section class="veritas-globe-section" style="position: relative;" data-controller="map-toggle" data-journey-target="globeSection">

    <!-- Cinematic search loading overlay — driven by search_intelligence_controller.js -->
    <div id="intel-loading-overlay"
         style="display:none; position:absolute; inset:0; z-index:200;
                background:rgba(5,7,15,0.82); backdrop-filter:blur(6px);
                flex-direction:column; align-items:center; justify-content:center;
                pointer-events:none;">
      <div style="text-align:center; max-width:340px;">
        <div id="intel-loading-stage"
             style="font-family:'JetBrains Mono',monospace; font-size:0.78rem;
                    color:#00f0ff; letter-spacing:0.12em; line-height:1.7;
                    text-shadow:0 0 12px rgba(0,240,255,0.6);
                    min-height:2.4em;"></div>
        <div style="margin-top:16px; display:flex; gap:6px; justify-content:center;">
          <span class="intel-loading-dot" style="width:6px;height:6px;border-radius:50%;background:#00f0ff;opacity:0.3;animation:veritas-pulse 1.2s ease-in-out infinite;"></span>
          <span class="intel-loading-dot" style="width:6px;height:6px;border-radius:50%;background:#00f0ff;opacity:0.3;animation:veritas-pulse 1.2s ease-in-out 0.4s infinite;"></span>
          <span class="intel-loading-dot" style="width:6px;height:6px;border-radius:50%;background:#00f0ff;opacity:0.3;animation:veritas-pulse 1.2s ease-in-out 0.8s infinite;"></span>
        </div>
      </div>
    </div>
    <style>
      @keyframes veritas-pulse {
        0%,100% { opacity:0.2; transform:scale(1); }
        50% { opacity:1; transform:scale(1.4); }
      }
      #intel-loading-overlay.is-visible { display:flex !important; }
      #intel-loading-overlay.is-fading {
        transition: opacity 0.6s ease;
        opacity: 0;
      }
    </style>

    <!-- Search/All Intel view toggle — hidden until search is active -->
    <div id="intel-view-toggle"
         class="d-none"
         data-controller="view-toggle"
         style="position: absolute; top: 12px; right: 12px; z-index: 100;">
      <div class="d-flex" style="background: rgba(10,12,20,0.88); border: 1px solid rgba(0,240,255,0.3); border-radius: 20px; padding: 3px; gap: 2px; backdrop-filter: blur(10px);">
        <button data-action="click->view-toggle#setSearch"
                data-view-toggle-target="searchBtn"
                style="font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; padding: 4px 12px; border-radius: 16px; border: none; background: #00f0ff; color: #0a0c14; letter-spacing: 0.06em; cursor: pointer; transition: all 0.2s;">
          SEARCH
        </button>
        <button data-action="click->view-toggle#setAll"
                data-view-toggle-target="allBtn"
                style="font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; padding: 4px 12px; border-radius: 16px; border: none; background: transparent; color: #64748b; letter-spacing: 0.06em; cursor: pointer; transition: all 0.2s;">
          ALL INTEL
        </button>
      </div>
    </div>

    <!-- Globe control toggles -->
    <div class="vt-globe-toggles">
      <button class="vt-globe-toggle-btn vt-heatmap-toggle"
              data-controller="heatmap-toggle"
              data-heatmap-toggle-target="btn"
              data-action="click->heatmap-toggle#toggle"
              title="Toggle threat heatmap thermal layer">
        <span class="vt-toggle-icon">&#9608;</span>
        <span data-heatmap-toggle-target="label">THERMAL</span>
      </button>
      <button class="vt-globe-toggle-btn vt-daynight-toggle"
              data-controller="daynight-toggle"
              data-action="click->daynight-toggle#toggle"
              title="Toggle day/night globe view">
        <span class="vt-toggle-icon">&#9788;</span>
        <span data-daynight-toggle-target="label">DAY</span>
      </button>
      <button class="vt-globe-toggle-btn vt-isolate-toggle"
              data-controller="isolate-toggle"
              data-isolate-toggle-target="btn"
              data-action="click->isolate-toggle#toggle"
              title="Hide isolated signals (no arcs)">
        <span class="vt-toggle-icon">⊘</span>
        <span data-isolate-toggle-target="label">ISOLATES</span>
      </button>
      <button class="vt-globe-toggle-btn vt-flat-toggle"
              data-map-toggle-target="btn"
              data-action="click->map-toggle#toggle"
              title="Toggle flat world map projection">
        <span class="vt-toggle-icon">◫</span>
        <span data-map-toggle-target="label">GLOBE</span>
      </button>
    </div>

    <div class="veritas-crosshair top"></div>
    <div class="veritas-crosshair bottom"></div>
    <div class="veritas-crosshair left"></div>
    <div class="veritas-crosshair right"></div>

    <div class="vt-journey-hud-layer" data-journey-target="hudLayer"></div>

    <!-- 3D Globe View -->
    <div id="globe-container"
         data-controller="globe"
         data-map-toggle-target="globe"
         data-globe-data-url-value="/api/globe_data"
         style="width: 100%; height: 100%;">
    </div>

    <!-- 2D Flat Map View (D3) -->
    <div id="flat-map-container"
         class="d-none"
         data-controller="flat-map"
         data-map-toggle-target="flat"
         data-flat-map-data-url-value="/api/globe_data"
         style="width: 100%; height: 100%; position: absolute; top: 0; left: 0;">
    </div>

    <!-- Overlay stats (bottom-left of globe, above timeline) -->
    <div class="globe-overlay-stats">
      <div class="globe-stat">
        <span class="stat-value text-primary"><%= @signal_count %></span>
        <span class="stat-label">SIGNALS</span>
      </div>
      <div class="globe-stat">
        <span class="stat-value text-success"><%= Region.count %></span>
        <span class="stat-label">REGIONS</span>
      </div>
      <div class="globe-stat">
        <span class="stat-value text-warning"><%= NarrativeArc.count %></span>
        <span class="stat-label">ARCS</span>
      </div>
    </div>

    <!-- Timeline Scrubber -->
    <div class="globe-timeline-bar"
         data-controller="timeline"
         data-timeline-min-value="<%= @timeline_min %>"
         data-timeline-max-value="<%= @timeline_max %>">
      <span class="timeline-label">TIMELINE</span>
      <button class="timeline-btn" data-action="click->timeline#rewind" title="Jump to oldest">◄◄</button>
      <input type="range"
             class="timeline-scrubber"
             data-timeline-target="scrubber"
             data-action="input->timeline#scrub"
             min="0" max="100" value="100">
      <span class="timeline-date" data-timeline-target="date">LIVE</span>
      <button class="timeline-btn"
              data-timeline-target="liveBtn"
              data-action="click->timeline#goLive">LIVE</button>
    </div>
  </section>

  <!-- RIGHT SIDEBAR: Status Panel -->
  <aside class="veritas-status-sidebar mobile-hidden">

    <!-- Narrative Lens Panel: rendered by narrative_lens_controller when a perspective is active -->
    <div id="narrative-lens-panel"
         class="d-none"
         data-controller="narrative-lens"
         style="padding: 8px 8px 0;"></div>

    <div class="vt-journey-summary-slot" data-journey-target="summarySlot"></div>

    <div class="veritas-panel-header">
      <span class="panel-icon">&#9632;</span>
      <span class="panel-title">THREAT_MATRIX</span>
    </div>

    <div class="p-3">
      <% Article.joins(:region).group('regions.name', 'regions.threat_level').count.each do |key, count| %>
        <div class="veritas-threat-row mb-3">
          <div class="d-flex justify-content-between mb-1">
            <span class="threat-region"><%= key[0] %></span>
            <span class="threat-badge <%= key[1].to_i == 3 ? 'badge-severe' : (key[1].to_i == 2 ? 'badge-elevated' : 'badge-normal') %>">
              <%= key[1].to_i == 3 ? 'SEVERE' : (key[1].to_i == 2 ? 'ELEVATED' : 'NORMAL') %>
            </span>
          </div>
          <div class="veritas-threat-bar">
            <div class="threat-bar-fill threat-<%= key[1].to_i == 3 ? 'severe' : (key[1].to_i == 2 ? 'elevated' : 'normal') %>"
                 style="width: <%= [(count * 10), 100].min %>%"></div>
          </div>
          <span class="threat-count"><%= count %> signals</span>
        </div>
      <% end %>

      <hr class="veritas-divider mt-4 mb-3">

      <div class="veritas-panel-header mb-3">
        <span class="panel-icon">&#9675;</span>
        <span class="panel-title">SYSTEM_STATUS</span>
      </div>

      <div class="veritas-sys-row">
        <span class="sys-label">AI LAYER</span>
        <span class="sys-value text-warning">PENDING</span>
      </div>
      <div class="veritas-sys-row">
        <span class="sys-label">WEBSOCKET</span>
        <span class="sys-value text-success">ONLINE</span>
      </div>
      <div class="veritas-sys-row">
        <span class="sys-label">DATA FEED</span>
        <span class="sys-value text-success">ONLINE</span>
      </div>
      <div class="veritas-sys-row">
        <span class="sys-label">DATABASE</span>
        <span class="sys-value text-success">ONLINE</span>
      </div>

      <hr class="veritas-divider mt-4 mb-3">

      <%# ──────────────────────────────────────────────────────
          REGIONAL ANALYSIS — Verdict Panel
          Admins: trigger new analysis + see live progress.
          All users: see latest verdict badge + open dossier.
      ─────────────────────────────────────────────────────── %>
      <div class="veritas-panel-header mb-2">
        <span class="panel-icon">&#9670;</span>
        <span class="panel-title">REGIONAL_ANALYSIS</span>
      </div>

      <% @regions.each do |region| %>
        <% report = @latest_reports[region.id] %>
        <div class="veritas-analysis-block mb-3"
             data-controller="analysis-progress"
             data-analysis-progress-region-id-value="<%= region.id %>"
             data-analysis-progress-report-id-value="<%= report&.id || 0 %>"
             data-analysis-progress-poll-interval-value="2500"
             id="region-analysis-<%= region.id %>">

          <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="threat-region"><%= region.name %></span>

            <div class="d-flex align-items-center gap-2">
              <%# Verdict badge — visible to all users when a report exists %>
              <% if report %>
                <span class="veritas-verdict-pill"
                      style="color: <%= report.verdict_color %>; border-color: <%= report.verdict_color %>40;">
                  <%= report.verdict %>
                </span>
              <% end %>

              <%# All logged-in users can trigger analysis %>
              <% if user_signed_in? %>
                <button data-action="click->analysis-progress#run"
                        data-analysis-progress-target="button"
                        class="btn veritas-analysis-btn">
                  &#x25B6; RUN
                </button>
              <% end %>
            </div>
          </div>

          <%# Progress bar: filled + verdict color if report exists, empty if not %>
          <div class="veritas-analysis-bar-track">
            <div data-analysis-progress-target="bar"
                 class="veritas-analysis-bar-fill"
                 style="width: <%= report ? '100%' : '0%' %>;
                        background: linear-gradient(90deg, <%= report ? report.verdict_color : 'var(--neon-blue)' %>, rgba(0,0,0,0));"></div>
          </div>

          <%# Status label: last updated timestamp or empty %>
          <p data-analysis-progress-target="label" class="veritas-analysis-status">
            <% if report %>
              <span class="veritas-glitch-text"
                    data-text="Updated <%= time_ago_in_words(report.created_at) %> ago">
                Updated <%= time_ago_in_words(report.created_at) %> ago
              </span>
            <% end %>
          </p>

          <%# Dossier link — pre-seeded if a report already exists %>
          <div data-analysis-progress-target="result"
               class="veritas-analysis-result <%= report ? '' : 'd-none' %>">
            <% if report %>
              <%= link_to intelligence_report_path(report),
                    class: "btn veritas-dossier-btn w-100 mt-1" do %>
                OPEN INTEL DOSSIER
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <hr class="veritas-divider mt-4 mb-3">
      
      <div class="veritas-panel-header mb-2">
        <span class="panel-icon">⏱️</span>
        <span class="panel-title">HOP_TIMELINE</span>
      </div>
      
      <div id="hop-timeline" class="hop-timeline-container">
        <div class="hop-timeline-empty">
          Click on a narrative segment to view hop details
        </div>
        <div id="hop-details" class="hop-details d-none">
          <!-- Filled by JavaScript -->
        </div>
      </div>
    </div>
  </aside>

</div><!-- .veritas-dashboard -->

<!-- Mobile Tab Bar (hidden on desktop) -->
<nav class="veritas-mobile-tabs"
     data-controller="mobile-tabs">
  <button class="mobile-tab is-active"
          data-mobile-tabs-target="tab"
          data-panel="globe"
          data-action="click->mobile-tabs#show">
    ◎ GLOBE
  </button>
  <button class="mobile-tab"
          data-mobile-tabs-target="tab"
          data-panel="feed"
          data-action="click->mobile-tabs#show">
    ⊞ INTEL
  </button>
  <button class="mobile-tab"
          data-mobile-tabs-target="tab"
          data-panel="threat"
          data-action="click->mobile-tabs#show">
    ◈ THREAT
  </button>
</nav>

</div><!-- .veritas-war-room -->
