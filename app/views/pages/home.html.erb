<!-- VERITAS War Room -->
<div class="veritas-war-room"
     data-controller="narrative-dna tribunal">

<!-- Perspective Selector Bar -->
<div class="veritas-perspective-bar"
     data-controller="perspective">
  <span class="perspective-label">LENS</span>

  <button class="veritas-perspective-pill"
          style="--pill-color: #64748b;"
          data-perspective-id="all"
          data-perspective-target="pill"
          data-action="click->perspective#select">
    ALL_SOURCES
  </button>

  <% @perspective_filters.each do |filter| %>
    <button class="veritas-perspective-pill"
            style="--pill-color: <%= filter.color %>;"
            data-perspective-id="<%= filter.id %>"
            data-perspective-target="pill"
            data-action="click->perspective#select">
      <%= filter.name.upcase.tr(' ', '_') %>
    </button>
  <% end %>

  <button class="vt-glass-toggle"
          data-controller="view-mode"
          data-action="click->view-mode#toggle"
          title="Toggle glassmorphism view">
    <span class="vt-glass-toggle-icon">◫</span>
    <span data-view-mode-target="label">SOLID</span>
  </button>
</div>

<!-- VERITAS Main Dashboard -->
<div class="veritas-dashboard">

  <!-- LEFT SIDEBAR: Live Intelligence Feed -->
  <aside class="veritas-feed-sidebar mobile-hidden">
    <div class="veritas-panel-header">
      <span class="panel-icon">🔥</span>
      <span class="panel-title">HIGH‑THREAT SIGNALS</span>
      <span class="panel-badge"><%= @hot_articles.count %> HOT</span>
    </div>

    <div class="veritas-feed-list">
      <% @hot_articles.each do |article| %>
        <div class="veritas-feed-card"
             data-controller="feed-card"
             data-feed-card-lat-value="<%= article.latitude %>"
             data-feed-card-lng-value="<%= article.longitude %>"
             data-feed-card-article-id-value="<%= article.id %>"
             data-article-id="<%= article.id %>"
             data-action="click->feed-card#select">

          <!-- Source + Time + Threat + Open link Row -->
          <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="feed-source"><%= article.source_name %></span>
            <div class="d-flex align-items-center gap-2">
              <% if article.ai_analysis&.threat_level %>
                <span class="feed-threat" style="color: <%= article.ai_analysis.threat_color %>;">
                  THREAT <%= article.ai_analysis.threat_level %>
                </span>
              <% end %>
              <span class="feed-time"><%= time_ago_in_words(article.published_at) %> ago</span>
              <%= link_to "→", article_path(article),
                    class: "feed-card-open-link",
                    data: { turbo: false, action: "click->feed-card#openArticle" } %>
            </div>
          </div>

          <!-- Headline -->
          <p class="feed-headline"><%= truncate(article.headline, length: 110) %></p>

          <!-- Country + Coordinates + Intelligence Actions Row -->
          <div class="d-flex justify-content-between align-items-center">
            <span class="feed-location">
              <i class="fa fa-map-marker-alt me-1"></i>
              <%= article.country.name %> [<%= article.country.iso_code %>]
            </span>
            <div class="d-flex align-items-center gap-1">
              <button class="ndna-trigger-btn"
                      data-action="click->feed-card#openDna"
                      title="View Narrative DNA">◈ DNA</button>
              <button class="tribunal-trigger-btn"
                      data-action="click->feed-card#openTribunal"
                      title="Open Intelligence Tribunal">⬟ TRIBUNAL</button>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </aside>

  <!-- CENTER: 3D Globe (Globe.gl) -->
  <section class="veritas-globe-section">
    <div class="veritas-crosshair top"></div>
    <div class="veritas-crosshair bottom"></div>
    <div class="veritas-crosshair left"></div>
    <div class="veritas-crosshair right"></div>

    <div id="globe-container"
         data-controller="globe"
         data-globe-data-url-value="/api/globe_data"
         style="width: 100%; height: 100%;">
    </div>

    <!-- Overlay stats (bottom-left of globe, above timeline) -->
    <div class="globe-overlay-stats">
      <div class="globe-stat">
        <span class="stat-value text-primary"><%= @signal_count %></span>
        <span class="stat-label">SIGNALS</span>
      </div>
      <div class="globe-stat">
        <span class="stat-value text-success"><%= Region.count %></span>
        <span class="stat-label">REGIONS</span>
      </div>
      <div class="globe-stat">
        <span class="stat-value text-warning"><%= NarrativeArc.count %></span>
        <span class="stat-label">ARCS</span>
      </div>
    </div>

    <!-- Timeline Scrubber -->
    <div class="globe-timeline-bar"
         data-controller="timeline"
         data-timeline-min-value="<%= @timeline_min %>"
         data-timeline-max-value="<%= @timeline_max %>">
      <span class="timeline-label">TIMELINE</span>
      <button class="timeline-btn" data-action="click->timeline#rewind" title="Jump to oldest">◄◄</button>
      <input type="range"
             class="timeline-scrubber"
             data-timeline-target="scrubber"
             data-action="input->timeline#scrub"
             min="0" max="100" value="100">
      <span class="timeline-date" data-timeline-target="date">LIVE</span>
      <button class="timeline-btn"
              data-timeline-target="liveBtn"
              data-action="click->timeline#goLive">LIVE</button>
    </div>
  </section>

  <!-- RIGHT SIDEBAR: Status Panel -->
  <aside class="veritas-status-sidebar mobile-hidden">
    <div class="veritas-panel-header">
      <span class="panel-icon">&#9632;</span>
      <span class="panel-title">THREAT_MATRIX</span>
    </div>

    <div class="p-3">
      <% Article.joins(:region).group('regions.name', 'regions.threat_level').count.each do |key, count| %>
        <div class="veritas-threat-row mb-3">
          <div class="d-flex justify-content-between mb-1">
            <span class="threat-region"><%= key[0] %></span>
            <span class="threat-badge <%= key[1].to_i == 3 ? 'badge-severe' : (key[1].to_i == 2 ? 'badge-elevated' : 'badge-normal') %>">
              <%= key[1].to_i == 3 ? 'SEVERE' : (key[1].to_i == 2 ? 'ELEVATED' : 'NORMAL') %>
            </span>
          </div>
          <div class="veritas-threat-bar">
            <div class="threat-bar-fill threat-<%= key[1].to_i == 3 ? 'severe' : (key[1].to_i == 2 ? 'elevated' : 'normal') %>"
                 style="width: <%= [(count * 10), 100].min %>%"></div>
          </div>
          <span class="threat-count"><%= count %> signals</span>
        </div>
      <% end %>

      <hr class="veritas-divider mt-4 mb-3">

      <div class="veritas-panel-header mb-3">
        <span class="panel-icon">&#9675;</span>
        <span class="panel-title">SYSTEM_STATUS</span>
      </div>

      <div class="veritas-sys-row">
        <span class="sys-label">AI LAYER</span>
        <span class="sys-value text-warning">PENDING</span>
      </div>
      <div class="veritas-sys-row">
        <span class="sys-label">WEBSOCKET</span>
        <span class="sys-value text-success">ONLINE</span>
      </div>
      <div class="veritas-sys-row">
        <span class="sys-label">DATA FEED</span>
        <span class="sys-value text-success">ONLINE</span>
      </div>
      <div class="veritas-sys-row">
        <span class="sys-label">DATABASE</span>
        <span class="sys-value text-success">ONLINE</span>
      </div>

      <hr class="veritas-divider mt-4 mb-3">

      <%# ──────────────────────────────────────────────────────
          REGIONAL ANALYSIS — Verdict Panel
          Admins: trigger new analysis + see live progress.
          All users: see latest verdict badge + open dossier.
      ─────────────────────────────────────────────────────── %>
      <div class="veritas-panel-header mb-2">
        <span class="panel-icon">&#9670;</span>
        <span class="panel-title">REGIONAL_ANALYSIS</span>
      </div>

      <% @regions.each do |region| %>
        <% report = @latest_reports[region.id] %>
        <div class="veritas-analysis-block mb-3"
             data-controller="analysis-progress"
             data-analysis-progress-region-id-value="<%= region.id %>"
             data-analysis-progress-report-id-value="<%= report&.id || 0 %>"
             data-analysis-progress-poll-interval-value="2500"
             id="region-analysis-<%= region.id %>">

          <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="threat-region"><%= region.name %></span>

            <div class="d-flex align-items-center gap-2">
              <%# Verdict badge — visible to all users when a report exists %>
              <% if report %>
                <span class="veritas-verdict-pill"
                      style="color: <%= report.verdict_color %>; border-color: <%= report.verdict_color %>40;">
                  <%= report.verdict %>
                </span>
              <% end %>

              <%# All logged-in users can trigger analysis %>
              <% if user_signed_in? %>
                <button data-action="click->analysis-progress#run"
                        data-analysis-progress-target="button"
                        class="btn veritas-analysis-btn">
                  &#x25B6; RUN
                </button>
              <% end %>
            </div>
          </div>

          <%# Progress bar: filled + verdict color if report exists, empty if not %>
          <div class="veritas-analysis-bar-track">
            <div data-analysis-progress-target="bar"
                 class="veritas-analysis-bar-fill"
                 style="width: <%= report ? '100%' : '0%' %>;
                        background: linear-gradient(90deg, <%= report ? report.verdict_color : 'var(--neon-blue)' %>, rgba(0,0,0,0));"></div>
          </div>

          <%# Status label: last updated timestamp or empty %>
          <p data-analysis-progress-target="label" class="veritas-analysis-status">
            <% if report %>
              <span class="veritas-glitch-text"
                    data-text="Updated <%= time_ago_in_words(report.created_at) %> ago">
                Updated <%= time_ago_in_words(report.created_at) %> ago
              </span>
            <% end %>
          </p>

          <%# Dossier link — pre-seeded if a report already exists %>
          <div data-analysis-progress-target="result"
               class="veritas-analysis-result <%= report ? '' : 'd-none' %>">
            <% if report %>
              <%= link_to intelligence_report_path(report),
                    class: "btn veritas-dossier-btn w-100 mt-1" do %>
                OPEN INTEL DOSSIER
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <hr class="veritas-divider mt-4 mb-3">
      
      <div class="veritas-panel-header mb-2">
        <span class="panel-icon">⏱️</span>
        <span class="panel-title">HOP_TIMELINE</span>
      </div>
      
      <div id="hop-timeline" class="hop-timeline-container">
        <div class="hop-timeline-empty">
          Click on a narrative segment to view hop details
        </div>
        <div id="hop-details" class="hop-details d-none">
          <!-- Filled by JavaScript -->
        </div>
      </div>
    </div>
  </aside>

</div><!-- .veritas-dashboard -->

<!-- Mobile Tab Bar (hidden on desktop) -->
<nav class="veritas-mobile-tabs"
     data-controller="mobile-tabs">
  <button class="mobile-tab is-active"
          data-mobile-tabs-target="tab"
          data-panel="globe"
          data-action="click->mobile-tabs#show">
    ◎ GLOBE
  </button>
  <button class="mobile-tab"
          data-mobile-tabs-target="tab"
          data-panel="feed"
          data-action="click->mobile-tabs#show">
    ⊞ INTEL
  </button>
  <button class="mobile-tab"
          data-mobile-tabs-target="tab"
          data-panel="threat"
          data-action="click->mobile-tabs#show">
    ◈ THREAT
  </button>
</nav>

</div><!-- .veritas-war-room -->
