<div class="container-fluid px-4 py-4" data-controller="search">
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex align-items-center justify-content-between">
        <div>
          <h1 class="text-white mb-2" style="font-weight: 700; letter-spacing: -1px;">
            <i class="fa fa-crosshairs me-2 text-info"></i>
            VERITAS THREAT SEARCH<% if @query.present? %> // <span class="text-info"><%= @query.upcase %></span><% end %>
          </h1>
          <div class="veritas-meta text-info" style="font-size: 0.85rem;">
            [ ALGORITHM: <span class="text-white">SEMANTIC_VECTOR_PROXIMITY</span> ] // [ MODEL: <span class="text-white">TEXT-EMBEDDING-3-SMALL</span> ]
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Search Form with Autocomplete -->
  <div class="row mb-4">
    <div class="col-12">
      <form class="veritas-search-form position-relative" action="/search" method="get"
            data-search-target="searchForm" data-action="submit->search#submit">
        <div class="input-group input-group-lg">
          <span class="input-group-text bg-dark border-info text-info">
            <i class="fa fa-search"></i>
          </span>
          <input
            type="text"
            name="q"
            class="form-control bg-dark border-info text-white"
            placeholder="Search Intelligence Topics (e.g., 'Ukraine', 'Iran missiles', 'NATO deployment')..."
            data-search-target="queryInput"
            value="<%= @query %>"
            autocomplete="off"
          >
          <button class="btn btn-info" type="submit">
            <i class="fa fa-crosshairs me-2"></i>SEARCH
          </button>
          <button class="btn btn-outline-secondary" type="button" data-action="click->search#clear" title="Clear search">
            <i class="fa fa-times"></i>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Trending Topics -->
  <div class="row mb-4" data-search-target="trendingContainer">
    <!-- Filled by JavaScript -->
  </div>

  <!-- Search Results -->
  <div class="row" data-search-target="resultsContainer">
    <div class="col-12 d-flex justify-content-center">
    <div class="search-results-panel">
        
        <div class="mb-5 text-center">
          <p class="text-muted" style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">
            QUERY PARAMETER: <span class="text-white" style="background: rgba(56,189,248,0.1); padding: 4px 8px; border-radius: 4px; border: 1px solid rgba(56,189,248,0.3);">"<%= @query %>"</span>
          </p>
        </div>

        <% if @results.any? %>
          <div class="d-flex align-items-center gap-2 mb-4 pb-2" style="border-bottom: 1px solid rgba(56,189,248,0.2);">
            <span class="panel-icon" style="color: #38BDF8;">&#9632;</span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 1rem; color: white; letter-spacing: 2px;">NEAREST_NEIGHBOR_MATCHES [ <%= @results.count %> ]</span>
          </div>

          <div class="row g-4">
            <% @results.each_with_index do |article, index| %>
              <% analysis = article.ai_analysis %>
              <% trust = analysis&.trust_score&.to_i || 0 %>
              <% trust_color = trust >= 70 ? '#22c55e' : trust >= 40 ? '#f59e0b' : '#ef4444' %>

              <!-- Calculate an artificial match percentage based on order for UI flair -->
              <% match_percent = [99 - (index * 4) + rand(3), 50].max %>

              <div class="col-md-6 col-lg-4">
                <div class="veritas-feed-card h-100 position-relative" style="background: rgba(56,189,248,0.03); border: 1px solid rgba(56,189,248,0.15); transition: all 0.3s ease;">

                  <!-- Match Badge -->
                  <div class="d-flex justify-content-end mb-2">
                    <span style="background: #020817; border: 1px solid #38BDF8; color: #38BDF8; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; padding: 2px 8px; border-radius: 4px; font-weight: bold;">
                      <%= match_percent %>% MATCH
                    </span>
                  </div>

                  <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="feed-source px-2 py-1 fs-6"><%= article.source_name %></span>
                    <% if analysis.present? %>
                      <div class="d-flex align-items-center gap-2" style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;">
                        <span style="color: #64748b;">TRUST:</span>
                        <span style="color: <%= trust_color %>; font-weight: bold;"><%= trust %></span>
                      </div>
                    <% end %>
                  </div>
                  
                  <h3 class="mb-3" style="font-weight: 600; font-size: 1.1rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                    <a href="<%= article_path(article) %>" class="text-white text-decoration-none feed-headline-link">
                      <%= article.headline %>
                    </a>
                  </h3>
                  
                  <div class="veritas-sys-row border-0 py-1 mb-3 bg-transparent px-0">
                    <span class="sys-label" style="font-size: 0.65rem;">CONTEXT SUMMARY</span>
                  </div>
                  <p style="font-family: 'Inter', sans-serif; font-size: 0.85rem; color: #94a3b8; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;">
                    <%= analysis&.summary || ActionController::Base.helpers.strip_tags(article.content.to_s)[0..150] || "Content indexing..." %>
                  </p>

                  <div class="d-flex gap-2 mt-auto pt-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: #38BDF8; background: rgba(56,189,248,0.1); padding: 2px 6px; border-radius: 2px;">
                      <%= article.country&.iso_code || 'GLOBAL' %>
                    </span>
                    <% if analysis&.threat_level.present? %>
                      <% threat_colors = { 'CRITICAL' => '#ef4444', 'HIGH' => '#f97316', 'MODERATE' => '#f59e0b', 'LOW' => '#22c55e', 'NEGLIGIBLE' => '#64748b' } %>
                      <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: <%= threat_colors[analysis.threat_level] || '#64748b' %>; background: rgba(255,255,255,0.05); padding: 2px 6px; border-radius: 2px;">
                        <%= analysis.threat_level %>
                      </span>
                    <% end %>
                  </div>
                  
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-5">
            <i class="fa fa-folder-open fa-3x mb-3" style="color: #64748b;"></i>
            <h3 class="text-white" style="font-family: 'JetBrains Mono', monospace;">NO SEMANTIC MATCHES FOUND</h3>
            <p class="text-muted" style="max-width: 500px; margin: 0 auto;">
              The vector database could not find any intelligence reports conceptually related to your query.
            </p>
          </div>
        <% end %>

      </div>
    </div>
    </div>
  </div>
</div>
