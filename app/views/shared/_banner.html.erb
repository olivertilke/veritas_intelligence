<nav class="navbar veritas-navbar px-3 py-3 d-flex justify-content-between align-items-center border-bottom border-secondary mb-4">
  <a class="navbar-brand veritas-brand m-0" href="<%= root_path %>">
    <span class="brand-pulse"></span>
    <span class="brand-text">VERITAS</span>
    <span class="brand-sub">// WAR ROOM</span>
  </a>

  <div class="navbar-center d-none d-md-flex align-items-center gap-4 flex-grow-1 justify-content-center">
    <div class="veritas-status me-3">
      <span class="status-dot live"></span>
      <span class="status-label">SYSTEM ONLINE</span>
    </div>
    
    <!-- Semantic Search Bar -->
    <form action="<%= search_path %>" method="get" class="d-flex align-items-center" style="width: 400px;">
      <div class="input-group">
        <span class="input-group-text bg-transparent border-info text-info" style="border-right: none;">
          <i class="fa fa-search"></i>
        </span>
        <input type="text" name="q" class="form-control bg-transparent border-info text-white shadow-none" placeholder="Semantic Threat Search (e.g. 'maritime escalation')" value="<%= params[:q] %>" style="border-left: none; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;" required>
        <button class="btn btn-outline-info veritas-btn-outline" type="submit" style="border-left: none;">
          <i class="fa fa-arrow-right"></i>
        </button>
      </div>
    </form>
  </div>

  <div class="d-flex align-items-center gap-4">
    <!-- Convergence Alerts Link -->
    <% convergence_count = NarrativeConvergence.active.count rescue 0 %>
    <%= link_to narrative_convergences_path,
          class: "d-none d-lg-flex align-items-center gap-2",
          style: "text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #{convergence_count > 0 ? '#ef4444' : '#475569'}; letter-spacing: 1px; transition: color 0.2s;",
          data: { turbo: false } do %>
      <i class="fa fa-radiation" style="<%= convergence_count > 0 ? 'animation: pulse 1.5s infinite;' : '' %>"></i>
      CONVERGENCES
      <% if convergence_count > 0 %>
        <span style="background: #ef4444; color: white; font-size: 0.6rem; padding: 1px 5px; border-radius: 3px;"><%= convergence_count %></span>
      <% end %>
    <% end %>

    <!-- Time & Weather Widget -->
    <div class="d-flex align-items-center gap-3 veritas-meta">
      <div data-controller="time" class="d-flex align-items-center text-monospace">
        <span data-time-target="output">00:00:00</span>
      </div>
      <div data-controller="weather" class="d-flex align-items-center text-monospace text-muted">
        <span data-weather-target="output">Wait...</span>
      </div>
    </div>

    <!-- User Section -->
    <div class="d-flex align-items-center gap-3">
      <% if user_signed_in? %>
        <% if current_user.admin? %>
          <%= link_to "ADMIN PANEL", admin_users_path, class: "btn btn-outline-warning btn-sm veritas-btn-outline me-2" %>
        <% end %>
        <%= link_to "SAVED ARTICLES", saved_articles_path, class: "btn btn-outline-info btn-sm veritas-btn-outline me-2", style: "font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;" %>
        <div class="d-flex align-items-center gap-2">
          <%= image_tag "https://api.dicebear.com/7.x/bottts/svg?seed=#{current_user.email}", class: "rounded-circle bg-dark border border-secondary", style: "width: 32px; height: 32px;", alt: "Avatar" %>
          <span class="veritas-meta d-none d-md-inline ms-1"><%= current_user.email %></span>
        </div>
        <%= link_to "SIGN OUT", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-danger btn-sm veritas-btn-outline ms-2" %>
      <% else %>
        <%= link_to "SIGN IN", new_user_session_path, class: "btn btn-outline-primary btn-sm veritas-btn-outline" %>
      <% end %>
    </div>
  </div>
</nav>
