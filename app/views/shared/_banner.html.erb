<nav class="navbar veritas-navbar px-3 py-3 d-flex justify-content-between align-items-center border-bottom border-secondary mb-0">
  <a class="navbar-brand veritas-brand m-0" href="<%= root_path %>">
    <span class="brand-pulse"></span>
    <span class="brand-text">VERITAS</span>
    <span class="brand-sub">// WAR ROOM</span>
  </a>

  <div class="navbar-center d-none d-md-flex align-items-center gap-5 flex-grow-1 justify-content-center">
    <!-- System Status (Visible Always but styled differently for Welcome) -->
    <div class="veritas-status <%= (controller_name == 'pages' && action_name == 'welcome') ? 'hero-status-widget' : '' %>">
      <span class="status-dot live"></span>
      <span class="status-label">SYSTEM ONLINE</span>
    </div>

    <% if controller_name == "pages" && action_name == "welcome" %>
      <!-- High-Trust Data Widgets for Welcome Page -->
      <div class="d-flex align-items-center gap-4 hero-meta-widgets">
        <div data-controller="ping" class="d-flex align-items-center gap-2 text-monospace">
          <span class="widget-label">LATENCY:</span>
          <span data-ping-target="output" class="widget-value">--ms</span>
        </div>
        
        <div data-controller="time" class="d-flex align-items-center gap-2 text-monospace">
          <span class="widget-label">U_TIME:</span>
          <span data-time-target="output" class="widget-value">00:00:00</span>
        </div>

        <div data-controller="weather" class="d-flex align-items-center gap-2 text-monospace">
          <span class="widget-label">ENV_SIG:</span>
          <span data-weather-target="output" class="widget-value">Wait...</span>
        </div>
      </div>
    <% else %>
      <!-- Live Intelligence Search Bar (Hidden on Welcome) -->
      <div data-controller="search-intelligence" style="width: 440px;">
        <form action="<%= search_path %>" method="get"
              class="d-flex align-items-center"
              data-action="submit->search-intelligence#submit">
          <div class="input-group">
            <span class="input-group-text bg-transparent border-info text-info" style="border-right: none;">
              <i class="fa fa-search"></i>
            </span>
            <input type="text"
                   name="q"
                   data-search-intelligence-target="input"
                   class="form-control bg-transparent border-info text-white shadow-none"
                   placeholder="Live Intelligence Search..."
                   value="<%= params[:q] %>"
                   autocomplete="off"
                   style="border-left: none; border-right: none; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;">
            <button type="button"
                    data-search-intelligence-target="clearBtn"
                    data-action="click->search-intelligence#clear"
                    class="btn bg-transparent border-info text-secondary d-none"
                    style="border-left: none; border-right: none; padding: 0 8px; font-size: 0.75rem;"
                    title="Clear search">
              <i class="fa fa-times"></i>
            </button>
            <a href="/search"
               target="_blank"
               rel="noopener noreferrer"
               data-turbo="false"
               data-search-intelligence-target="fullSearchLink"
               class="btn btn-outline-info veritas-btn-outline"
               style="border-left: none;"
               title="Open full search page in new tab">
              <i class="fa fa-arrow-right"></i>
            </a>
          </div>
        </form>
        <div class="d-flex align-items-center justify-content-between px-1 mt-1" style="min-height: 14px;">
          <span data-search-intelligence-target="statusBadge"
                class="d-none"
                style="font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.06em; transition: color 0.3s;">
          </span>
          <span data-search-intelligence-target="fetchingNotice"
                class="d-none"
                style="font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; color: #94a3b8; letter-spacing: 0.06em;">
            Fetching live intelligence...
          </span>
        </div>
      </div>
    <% end %>
  </div>

  <div class="d-flex align-items-center gap-4">
    <% unless controller_name == "pages" && action_name == "welcome" %>
      <!-- Briefings & Convergences (Hidden on Welcome) -->
      <%= link_to briefings_path,
            class: "d-none d-lg-flex align-items-center gap-2",
            style: "text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #94a3b8; letter-spacing: 1px; transition: color 0.2s;",
            data: { turbo: false } do %>
        <i class="fa fa-file-shield"></i>
        BRIEFINGS
      <% end %>

      <% convergence_count = NarrativeConvergence.active.count rescue 0 %>
      <%= link_to narrative_convergences_path,
            class: "d-none d-lg-flex align-items-center gap-2",
            style: "text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #{convergence_count > 0 ? '#ef4444' : '#475569'}; letter-spacing: 1px; transition: color 0.2s;",
            data: { turbo: false } do %>
        <i class="fa fa-radiation" style="<%= convergence_count > 0 ? 'animation: pulse 1.5s infinite;' : '' %>"></i>
        CONVERGENCES
        <% if convergence_count > 0 %>
          <span style="background: #ef4444; color: white; font-size: 0.6rem; padding: 1px 5px; border-radius: 3px;"><%= convergence_count %></span>
        <% end %>
      <% end %>

      <!-- Standard Time & Weather for non-welcome pages -->
      <div class="d-flex align-items-center gap-3 veritas-meta">
        <div data-controller="time" class="d-flex align-items-center text-monospace">
          <span data-time-target="output">00:00:00</span>
        </div>
        <div data-controller="weather" class="d-flex align-items-center text-monospace text-muted">
          <span data-weather-target="output">Wait...</span>
        </div>
      </div>
    <% end %>

    <!-- User Section -->
    <div class="d-flex align-items-center gap-3">
      <% if user_signed_in? %>
        <% if current_user.admin? %>
          <div onclick="document.dispatchEvent(new CustomEvent('veritas:trigger-surge'))" class="veritas-status" style="cursor:pointer;" title="">
            <span class="status-dot" style="background:#ff3a5e; animation: pulse 1.5s infinite;"></span>
            <span class="status-label" style="color:#ff3a5e;">SURGE_MONITOR</span>
          </div>
        <% end %>
        <!-- Model Settings Gear -->
        <button class="model-settings-gear-btn"
                onclick="document.getElementById('model-settings-modal').classList.remove('d-none')"
                title="AI Model Configuration">
          <i class="fa fa-gear"></i>
        </button>
        <% if current_user.admin? %>
          <%= link_to "ADMIN PANEL", admin_users_path, class: "btn btn-outline-warning btn-sm veritas-btn-outline me-2" %>
        <% end %>
        <%= link_to "SAVED ARTICLES", saved_articles_path, class: "btn btn-outline-info btn-sm veritas-btn-outline me-2", style: "font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;" %>
        <% wl_count = current_user.saved_articles.count rescue 0 %>
        <%= link_to watchlist_saved_articles_path,
              class: "btn btn-sm veritas-btn-outline me-2",
              style: "font-family:'JetBrains Mono',monospace;font-size:0.7rem;
                      border-color:#{wl_count > 0 ? '#ef4444' : '#475569'};
                      color:#{wl_count > 0 ? '#ef4444' : '#475569'};" do %>
          <i class="fa fa-satellite-dish me-1"></i>WATCHLIST
          <% if wl_count > 0 %>
            <span style="background:#ef4444;color:white;font-size:0.55rem;padding:1px 5px;border-radius:3px;margin-left:3px;"><%= wl_count %></span>
          <% end %>
        <% end %>
        <div class="d-flex align-items-center gap-2">
          <%= image_tag "https://api.dicebear.com/7.x/bottts/svg?seed=#{current_user.email}", class: "rounded-circle bg-dark border border-secondary", style: "width: 32px; height: 32px;", alt: "Avatar" %>
          <span class="veritas-meta d-none d-md-inline ms-1"><%= current_user.email %></span>
        </div>
        <%= link_to "SIGN OUT", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-danger btn-sm veritas-btn-outline ms-2" %>
      <% else %>
        <%= link_to "SIGN IN", new_user_session_path, class: "btn btn-outline-primary btn-sm veritas-btn-outline" %>
      <% end %>
    </div>
  </div>
</nav>
