<!-- Floating Chat Button -->
<button id="veritasChatBtn" class="veritas-chat-toggle shadow-lg" style="position: fixed; bottom: 30px; right: 30px; z-index: 1050; border-radius: 50%; width: 60px; height: 60px; background: rgba(13, 17, 23, 0.95); border: 1px solid #38BDF8; color: #38BDF8; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 0 20px rgba(56,189,248,0.2) !important;">
  <i class="fa fa-comment-dots fa-xl"></i>
</button>

<!-- Full Chat Interface -->
<div id="veritasChatPanel" class="veritas-feed-card shadow-lg" style="position: fixed; bottom: 100px; right: 30px; z-index: 1050; width: 450px; height: 550px; background: rgba(13, 17, 23, 0.98); border: 1px solid rgba(56,189,248,0.4); border-radius: 12px; display: none; flex-direction: column; overflow: hidden; backdrop-filter: blur(10px);">
  
  <!-- Header -->
  <div class="chat-header p-3" style="background: rgba(56,189,248,0.1); border-bottom: 1px solid rgba(56,189,248,0.2); display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h6 class="mb-0 text-white" style="font-family: 'JetBrains Mono', monospace; font-weight: bold; letter-spacing: 1px;">
        <i class="fa fa-brain text-info me-2"></i> VERITAS RAG CORE
      </h6>
      <div id="chatStatusBar" style="font-size: 0.65rem; color: #38BDF8; font-family: 'JetBrains Mono', monospace; margin-top: 2px;">
        [ STATUS: ONLINE ] | [ MODEL: CLAUDE-HAIKU ]
      </div>
    </div>
    <button id="closeChatBtn" class="btn btn-link text-muted p-0 shadow-none text-decoration-none" style="font-size: 1.2rem;">
      <i class="fa fa-times"></i>
    </button>
  </div>

  <!-- Perspective Lens Selector -->
  <% perspectives = PerspectiveFilter.all rescue [] %>
  <% if perspectives.any? %>
    <div style="padding:7px 12px 8px;border-bottom:1px solid rgba(56,189,248,0.12);background:rgba(0,0,0,0.15);">
      <div style="font-family:'JetBrains Mono',monospace;font-size:0.5rem;color:#475569;letter-spacing:1.5px;margin-bottom:5px;">PERSPECTIVE LENS</div>
      <div style="display:flex;flex-wrap:wrap;gap:4px;">
        <button class="perspective-pill active-pill" data-perspective-id=""
                style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;padding:2px 8px;
                       border-radius:3px;cursor:pointer;border:1px solid rgba(100,116,139,0.5);
                       background:rgba(100,116,139,0.15);color:#94a3b8;letter-spacing:0.5px;
                       transition:all 0.15s;">
          NEUTRAL
        </button>
        <% perspectives.each do |pf| %>
          <button class="perspective-pill" data-perspective-id="<%= pf.id %>"
                  data-color="<%= pf.color %>" data-name="<%= pf.name.upcase %>"
                  style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;padding:2px 8px;
                         border-radius:3px;cursor:pointer;
                         border:1px solid <%= pf.color %>40;
                         background:<%= pf.color %>12;
                         color:<%= pf.color %>cc;letter-spacing:0.5px;
                         transition:all 0.15s;">
            <%= pf.name.upcase.gsub(' MEDIA','').gsub(' MAINSTREAM','') %>
          </button>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Messages Area -->
  <div id="chatMessages" class="chat-messages p-3 flex-grow-1" style="overflow-y: auto; display: flex; flex-direction: column; gap: 15px;">
    <!-- System Welcome Message -->
    <div class="chat-message system-msg p-3" style="background: rgba(56,189,248,0.05); border-left: 3px solid #38BDF8; border-radius: 4px; font-family: 'Inter', sans-serif; font-size: 0.85rem; color: #e2e8f0; line-height: 1.5;">
      <strong style="color: #38BDF8; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; display: block; margin-bottom: 5px;">SYSTEM INITIALIZED</strong>
      Welcome to the VERITAS Retrieval-Augmented Generation (RAG) assistant. I can search our vector database and synthesize intelligence briefings for you. What do you need to know?
    </div>
  </div>

  <!-- Input Area -->
  <div class="chat-input-area p-3" style="border-top: 1px solid rgba(56,189,248,0.2); background: rgba(0,0,0,0.2);">
    <form id="ragChatForm" class="d-flex align-items-center gap-2">
      <input type="text" id="chatInput" class="form-control bg-transparent text-white shadow-none" placeholder="Query VERITAS..." autocomplete="off" style="border: 1px solid rgba(56,189,248,0.3); font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;" required>
      <button type="submit" id="chatSubmitBtn" class="btn btn-outline-info veritas-btn-outline" style="border-radius: 4px; width: 45px; height: calc(1.5em + .75rem + 2px);">
        <i class="fa fa-paper-plane pos-abs-center"></i>
      </button>
    </form>
  </div>
  
</div>

<style>
  .veritas-chat-toggle:hover {
    background: rgba(56,189,248,0.1) !important;
    transform: scale(1.05);
  }
  
  .chat-message.user-msg {
    align-self: flex-end;
    background: rgba(56,189,248,0.15);
    border: 1px solid rgba(56,189,248,0.3);
    border-radius: 12px 12px 0 12px;
    padding: 10px 14px;
    max-width: 85%;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: white;
  }
  
  .chat-message.rag-msg {
    align-self: flex-start;
    background: rgba(13, 17, 23, 0.8);
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 12px 12px 12px 0;
    padding: 12px 14px;
    max-width: 90%;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #e2e8f0;
    line-height: 1.5;
  }
  
  .chat-message.rag-msg strong {
    color: #38BDF8;
  }
  
  /* Loading dots animation */
  .typing-indicator span {
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: #38BDF8;
    border-radius: 50%;
    margin-right: 3px;
    animation: typing 1.4s infinite ease-in-out both;
  }
  .typing-indicator span:nth-child(1) { animation-delay: -0.32s; }
  .typing-indicator span:nth-child(2) { animation-delay: -0.16s; }
  @keyframes typing {
    0%, 80%, 100% { transform: scale(0); }
    40% { transform: scale(1); }
  }
  
  /* Scrollbar override for chat */
  #chatMessages::-webkit-scrollbar {
    width: 6px;
  }
  #chatMessages::-webkit-scrollbar-track {
    background: rgba(0,0,0,0.1);
  }
  #chatMessages::-webkit-scrollbar-thumb {
    background: rgba(56,189,248,0.3);
    border-radius: 3px;
  }
</style>

<script>
  (() => {
    const chatBtn = document.getElementById('veritasChatBtn');
    const chatPanel = document.getElementById('veritasChatPanel');
    const closeBtn = document.getElementById('closeChatBtn');
    const form = document.getElementById('ragChatForm');
    const input = document.getElementById('chatInput');
    const msgsArea = document.getElementById('chatMessages');
    const submitBtn = document.getElementById('chatSubmitBtn');
    let loadingDiv = null;
    let activePerspectiveId = '';

    if (!chatBtn) return; // guard against double-init

    // Perspective pill wiring
    document.querySelectorAll('.perspective-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.perspective-pill').forEach(b => {
          b.style.fontWeight = 'normal';
          b.style.boxShadow  = 'none';
        });
        btn.style.fontWeight = '700';
        btn.style.boxShadow  = `0 0 8px ${btn.dataset.color || 'rgba(100,116,139,0.4)'}60`;
        activePerspectiveId  = btn.dataset.perspectiveId || '';
        const statusBar      = document.getElementById('chatStatusBar');
        if (statusBar) {
          statusBar.textContent = activePerspectiveId
            ? `[ LENS: ${btn.dataset.name || btn.textContent.trim()} ] | [ MODEL: CLAUDE-HAIKU ]`
            : '[ STATUS: ONLINE ] | [ MODEL: CLAUDE-HAIKU ]';
        }
      });
    });

    // Auto-scroll helper
    const scrollToBottom = () => {
      msgsArea.scrollTop = msgsArea.scrollHeight;
    };

    // Remove typing indicator
    const hideTypingIndicator = () => {
      if (loadingDiv && loadingDiv.parentNode === msgsArea) {
        msgsArea.removeChild(loadingDiv);
      }
    };
    
    // Toggles
    chatBtn.addEventListener('click', () => {
      chatPanel.style.display = 'flex';
      chatBtn.style.display = 'none';
      input.focus();
      scrollToBottom();
    });
    
    closeBtn.addEventListener('click', () => {
      chatPanel.style.display = 'none';
      chatBtn.style.display = 'flex';
    });
    
    // Markdown formatting helper — links citations to source articles
    function formatResponse(text, sources = []) {
      const sourceMap = {};
      sources.forEach(s => { sourceMap[s.index] = s.id; });

      return text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\n/g, '<br>')
        .replace(/\[(\d+)\]/g, (match, num) => {
          const articleId = sourceMap[parseInt(num)];
          if (articleId) {
            return `<a href="/articles/${articleId}" target="_blank"
              style="color:#22c55e;font-family:'JetBrains Mono',monospace;font-weight:bold;
                     text-decoration:none;border-bottom:1px dotted rgba(34,197,94,0.5);">[${num}]</a>`;
          }
          return `<span style="color:#22c55e;font-family:'JetBrains Mono',monospace;">[${num}]</span>`;
        });
    }
    
    // Submit Handler
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const query = input.value.trim();
      if (!query) return;
      
      // Add User Message
      const userDiv = document.createElement('div');
      userDiv.className = 'chat-message user-msg';
      userDiv.textContent = query;
      msgsArea.appendChild(userDiv);
      
      input.value = '';
      scrollToBottom();
      
      // Add Loading Indicator
      loadingDiv = document.createElement('div');
      loadingDiv.className = 'chat-message rag-msg typing-indicator';
      loadingDiv.innerHTML = '<span></span><span></span><span></span> <span style="font-family:JetBrains Mono; font-size:0.6rem; color:#64748b; background:transparent; margin-left:8px; animation:none;">CROSS-REFERENCING VECTOR DB...</span>';
      msgsArea.appendChild(loadingDiv);
      scrollToBottom();
      
      // Disable Input while fetching
      input.disabled = true;
      submitBtn.disabled = true;
      
      try {
        const response = await fetch('/chat', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          },
          body: JSON.stringify({ message: query, perspective_id: activePerspectiveId || null })
        });
        
        const data = await response.json();
        hideTypingIndicator();

        const ragDiv = document.createElement('div');
        ragDiv.className = 'chat-message rag-msg';

        // Active perspective badge
        if (activePerspectiveId) {
          const activePill = document.querySelector(`.perspective-pill[data-perspective-id="${activePerspectiveId}"]`);
          if (activePill) {
            const lensDiv = document.createElement('div');
            const lensColor = activePill.dataset.color || '#64748b';
            lensDiv.style.cssText = `font-family:'JetBrains Mono',monospace;font-size:0.55rem;letter-spacing:1.5px;margin-bottom:4px;`;
            lensDiv.innerHTML = `<span style="color:${lensColor};border:1px solid ${lensColor}30;background:${lensColor}12;padding:2px 7px;border-radius:2px;">LENS: ${activePill.dataset.name}</span>`;
            ragDiv.appendChild(lensDiv);
          }
        }

        // Confidence badge
        if (data.confidence) {
          const confColors = { HIGH: '#22c55e', MEDIUM: '#eab308', LOW: '#ef4444' };
          const color = confColors[data.confidence] || '#64748b';
          const badge = document.createElement('div');
          badge.style.cssText = `font-family:'JetBrains Mono',monospace;font-size:0.55rem;letter-spacing:1.5px;margin-bottom:6px;`;
          badge.innerHTML = `<span style="color:${color};border:1px solid ${color}30;background:${color}12;padding:2px 7px;border-radius:2px;">CONFIDENCE: ${data.confidence}</span>`;
          ragDiv.appendChild(badge);
        }

        const responseBody = document.createElement('div');
        responseBody.innerHTML = formatResponse(data.response, data.sources || []);
        ragDiv.appendChild(responseBody);

        // Compact sources footer
        if (data.sources && data.sources.length > 0) {
          const footer = document.createElement('div');
          footer.style.cssText = 'margin-top:8px;padding-top:8px;border-top:1px solid rgba(56,189,248,0.15);font-family:"JetBrains Mono",monospace;font-size:0.65rem;color:#64748b;';
          footer.innerHTML = 'SOURCES: ' + data.sources.map(s =>
            `<a href="/articles/${s.id}" target="_blank"
               style="color:#38bdf8;text-decoration:none;margin-right:10px;">[${s.index}] ${s.source_name}</a>`
          ).join('');
          ragDiv.appendChild(footer);
        }

        msgsArea.appendChild(ragDiv);
        scrollToBottom();
        
      } catch (error) {
        hideTypingIndicator();
        const errDiv = document.createElement('div');
        errDiv.className = 'chat-message rag-msg';
        errDiv.innerHTML = '<span class="text-danger">Connection Error. VERITAS DB unreachable.</span>';
        msgsArea.appendChild(errDiv);
      } finally {
        input.disabled = false;
        submitBtn.disabled = false;
        input.focus();
        scrollToBottom();
      }
    });
  })();
</script>
